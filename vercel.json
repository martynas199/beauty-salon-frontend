{
  "framework": "vite",
  "installCommand": "npm install --include=dev --force",
  "buildCommand": "node ./node_modules/vite/bin/vite.js build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
